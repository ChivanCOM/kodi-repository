<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="plugin.audio.ibroadcast" name="iBroadcast Music" version="1.2.3" provider-name="FOBO">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>audio</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">Play your iBroadcast music library</summary>
      <description lang="en_GB">Browse and play music from your iBroadcast cloud music locker. Supports browsing by artist, album, and playlist, plus search.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="plugin.repository.ibroadcast" name="iBroadcast Repository" version="1.0.1" provider-name="FOBO">
    <extension point="xbmc.addon.repository" name="iBroadcast Repository">
      <info compressed="false">https://ChivanCOM.github.io/kodi-repository/addons.xml</info>
      <checksum>https://ChivanCOM.github.io/kodi-repository/addons.xml.md5</checksum>
      <datadir zip="true">https://ChivanCOM.github.io/kodi-repository/zips/</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">iBroadcast Repository</summary>
      <description lang="en_GB">Repository for iBroadcast Kodi addons.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="visualization.ibroadcast.albumart" name="iBroadcast Album Art" version="1.0.0" provider-name="FOBO">
    <extension point="xbmc.player.musicviz" library_osx="visualization.ibroadcast.albumart.dylib" library_linux="visualization.ibroadcast.albumart.so" library_android="visualization.ibroadcast.albumart.so" library_windows="visualization.ibroadcast.albumart.dll" />
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">Album Art Visualizer</summary>
      <description lang="en_GB">Displays the current track album art full-screen during playback.</description>
      <platform>all</platform>
    </extension>
  </addon>
</addons>
