<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="plugin.audio.ibroadcast" name="iBroadcast Music" version="1.2.25" provider-name="ChivanCOM">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>audio</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">Play your iBroadcast music library</summary>
      <description lang="en_GB">Browse and play music from your iBroadcast cloud music locker. Supports browsing by artist, album, and playlist, plus search.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="plugin.repository.chivancom" name="ChivanCOM Repository" version="1.0.9" provider-name="ChivanCOM">
    <extension point="xbmc.addon.repository" name="ChivanCOM Repository">
      <dir>
        <info compressed="false">https://ChivanCOM.github.io/kodi-repository/addons.xml</info>
        <checksum>https://ChivanCOM.github.io/kodi-repository/addons.xml.md5</checksum>
        <datadir zip="true">https://ChivanCOM.github.io/kodi-repository/zips/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">ChivanCOM Repository</summary>
      <description lang="en_GB">ChivanCOM Kodi addon repository.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="plugin.visualization.albumart" name="ChivanCOM Album Art visualization" version="1.2.16+osx" provider-name="ChivanCOM">
    <requires>
      <import addon="kodi.binary.global.main" version="2.0.0" />
      <import addon="kodi.binary.instance.visualization" version="4.0.0" />
    </requires>
    <extension point="xbmc.player.musicviz" library="plugin.visualization.albumart.dylib" />
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">ChivanCOM Album Art Visualizer</summary>
      <description lang="en_GB">Displays the current track album art full-screen during playback.</description>
      <platform>osx</platform>
    </extension>
  </addon>
  <addon id="plugin.visualization.albumart" name="ChivanCOM Album Art visualization" version="1.2.16+android" provider-name="ChivanCOM">
    <requires>
      <import addon="kodi.binary.global.main" version="2.0.0" />
      <import addon="kodi.binary.instance.visualization" version="4.0.0" />
    </requires>
    <extension point="xbmc.player.musicviz" library="plugin.visualization.albumart.so" />
    <extension point="xbmc.addon.metadata">
      <assets>
        <icon>icon.png</icon>
      </assets>
      <summary lang="en_GB">ChivanCOM Album Art Visualizer</summary>
      <description lang="en_GB">Displays the current track album art full-screen during playback.</description>
      <platform>android</platform>
    </extension>
  </addon>
</addons>
