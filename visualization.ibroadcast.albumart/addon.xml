<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="visualization.ibroadcast.albumart"
       name="iBroadcast Album Art"
       version="1.0.0"
       provider-name="FOBO">
<extension point="xbmc.player.musicviz"
             library_osx="visualization.ibroadcast.albumart.dylib"
             library_linux="visualization.ibroadcast.albumart.so"
             library_android="visualization.ibroadcast.albumart.so"
             library_windows="visualization.ibroadcast.albumart.dll"/>
  <extension point="xbmc.addon.metadata">
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="en_GB">Album Art Visualizer</summary>
    <description lang="en_GB">Displays the current track album art full-screen during playback.</description>
    <platform>all</platform>
  </extension>
</addon>
