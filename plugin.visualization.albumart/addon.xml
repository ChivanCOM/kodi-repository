<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.visualization.albumart"
       name="ChivanCOM Album Art"
       version="1.2.6"
       provider-name="ChivanCOM">
  <requires>
    <import addon="kodi.binary.global.main" version="2.0.0"/>
    <import addon="kodi.binary.instance.visualization" version="4.0.0"/>
  </requires>
  <extension point="xbmc.player.musicviz"
             library_osx="plugin.visualization.albumart.dylib"
             library_linux="plugin.visualization.albumart.so"
             library_android="plugin.visualization.albumart.so"
             library_windows="plugin.visualization.albumart.dll"/>
  <extension point="xbmc.addon.metadata">
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="en_GB">ChivanCOM Album Art Visualizer</summary>
    <description lang="en_GB">Displays the current track album art full-screen during playback.</description>
    <platform>all</platform>
  </extension>
</addon>
